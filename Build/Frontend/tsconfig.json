{
  "compilerOptions": {
    "target": "es2020",
    "module": "none",
    "lib": ["es2020", "dom"],
    "outDir": "../../Resources/Public/JavaScript",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
